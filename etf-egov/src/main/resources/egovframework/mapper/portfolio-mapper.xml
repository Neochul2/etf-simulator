<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.kopo.etf.mapper.PortfolioMapper">

    <select id="selectPortfolioList" resultType="com.kopo.etf.vo.PortfolioVO">
        SELECT
            id,
            symbol,
            invest_amt  AS investAmt,
            created_at  AS createdAt
        FROM portfolio
        ORDER BY created_at DESC
    </select>

    <insert id="insertPortfolio" parameterType="com.kopo.etf.vo.PortfolioVO"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO portfolio (symbol, invest_amt)
        VALUES (#{symbol}, #{investAmt})
    </insert>

    <delete id="deletePortfolio" parameterType="Long">
        DELETE FROM portfolio WHERE id = #{id}
    </delete>

</mapper>