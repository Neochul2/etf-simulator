<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- etf_dividend 테이블 SQL 정의 -->
<mapper namespace="com.kopo.etf.mapper.EtfDividendMapper">

    <!--
        특정 ETF의 최근 6개월 배당 내역 조회 (화면1)
        ex_div_date(배당락일) 최신순으로 6건만 조회
        (테이블정의서 5-2 참고사항 기준)
    -->
    <select id="selectRecentDividends" parameterType="String" resultType="com.kopo.etf.vo.EtfDividendVO">
        SELECT
            id,
            symbol,
            ex_div_date  AS exDivDate,
            pay_date     AS payDate,
            cash_amount  AS cashAmount,
            created_at   AS createdAt
        FROM etf_dividend
        WHERE symbol = #{symbol}
        ORDER BY ex_div_date DESC
        LIMIT 6
    </select>

</mapper>